{
  "dashboard": {
    "title": "AI Architecture Generator Monitoring",
    "tags": ["ai", "architecture", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Architecture Generation Duration (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(architecture_generation_duration_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(architecture_generation_total{status=\"error\"}[5m])",
            "legendFormat": "Errors"
          }
        ]
      },
      {
        "id": 4,
        "title": "Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(architecture_generation_total{status=\"success\"}[5m]) / rate(architecture_generation_total[5m]) * 100",
            "legendFormat": "Success %"
          }
        ]
      },
      {
        "id": 5,
        "title": "Rate Limit Hits",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{status=\"429\"}[5m])",
            "legendFormat": "Rate Limited"
          }
        ]
      },
      {
        "id": 6,
        "title": "Component Health",
        "type": "stat",
        "targets": [
          {
            "expr": "database_health_status",
            "legendFormat": "Database"
          },
          {
            "expr": "ai_service_health_status",
            "legendFormat": "AI Service"
          }
        ]
      },
      {
        "id": 7,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "Memory"
          }
        ]
      },
      {
        "id": 8,
        "title": "Response Time Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(architecture_generation_duration_bucket[5m])",
            "format": "heatmap"
          }
        ]
      }
    ],
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
