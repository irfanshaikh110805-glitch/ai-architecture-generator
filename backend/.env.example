# API Keys
# Get your free API key at: https://aistudio.google.com/app/apikey
# REQUIRED: The application will not work without a valid API key
# Note: Free tier has quota limits (~15 requests/minute, 1500/day)
# When quota is exceeded, the application will return an error (no fallback)
# For production use, consider upgrading to a paid plan
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Security (CRITICAL: Change in production!)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-min-32-chars-CHANGE-IN-PRODUCTION

# JWT Secret (for authentication)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars-CHANGE-IN-PRODUCTION

# Database Configuration
# For development: SQLite or local PostgreSQL
# For production: Use PostgreSQL with proper credentials
DATABASE_URL=postgresql://architech_user:your_password@localhost:5432/architech_db

# Redis Configuration (for caching and rate limiting)
REDIS_URL=redis://:your_redis_password@localhost:6379/0
REDIS_PASSWORD=your_redis_password_here

# CORS Configuration
# For production, set to your actual domain(s)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# Environment (development, staging, production)
ENVIRONMENT=development

# Monitoring (optional)
SENTRY_DSN=

# Supabase Configuration (optional - for additional features)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Docker-specific (used in docker-compose.yml)
POSTGRES_PASSWORD=your_postgres_password_here
GRAFANA_PASSWORD=your_grafana_password_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
