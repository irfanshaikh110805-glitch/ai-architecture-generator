"""
Comprehensive service layer tests
"""
import pytest
from unittest.mock import Mock, AsyncMock, patch
from services import ArchitectureService, UserService
from exceptions import NotFoundError, DuplicateResourceError
from schemas import ArchitectureResponse


@pytest.fixture
def mock_session():
    """Mock database session"""
    return AsyncMock()


@pytest.fixture
def mock_cache():
    """Mock cache service"""
    cache = AsyncMock()
    cache.get = AsyncMock(return_value=None)
    cache.set = AsyncMock(return_value=True)
    cache.delete = AsyncMock(return_value=True)
    return cache


@pytest.fixture
def mock_ai_service():
    """Mock AI service"""
    ai = AsyncMock()
    ai.generate_architecture = AsyncMock(
        return_value=ArchitectureResponse(
            features=[{"name": "Test Feature", "priority": "Must"}],
            database=[],
            apis=[],
            architecture={"type": "Monolith", "components": [], "tech_stack": {}},
            erDiagram="",
            architectureDiagram="",
            roadmap=[],
            estimation={"hours": "100", "team_size": "2", "cost": "$10,000"}
        )
    )
    return ai


@pytest.mark.asyncio
async def test_generate_architecture_cache_hit(mock_session, mock_cache, mock_ai_service):
    """Test architecture generation with cache hit"""
    # Setup cache to return cached data
    cached_data = {
        "features": [{"name": "Cached Feature", "priority": "Must"}],
        "database": [],
        "apis": [],
        "architecture": {"type": "Monolith", "components": [], "tech_stack": {}},
        "erDiagram": "",
        "architectureDiagram": "",
        "roadmap": [],
        "estimation": {"hours": "100", "team_size": "2", "cost": "$10,000"}
    }
    mock_cache.get = AsyncMock(return_value=cached_data)
    
    service = ArchitectureService(mock_session, mock_cache, mock_ai_service)
    result = await service.generate(user_id=1, idea="Test idea")
    
    # Should return cached data
    assert result.features[0]["name"] == "Cached Feature"
    # Should not call AI service
    mock_ai_service.generate_architecture.assert_not_called()


@pytest.mark.asyncio
async def test_generate_architecture_cache_miss(mock_session, mock_cache, mock_ai_service):
    """Test architecture generation with cache miss"""
    service = ArchitectureService(mock_session, mock_cache, mock_ai_service)
    
    with patch.object(service.repository, 'get_by_idea_hash', return_value=None):
        with patch.object(service.repository, 'create', return_value=Mock()):
            result = await service.generate(user_id=1, idea="Test idea")
    
    # Should call AI service
    mock_ai_service.generate_architecture.assert_called_once()
    # Should cache result
    mock_cache.set.assert_called_once()


@pytest.mark.asyncio
async def test_generate_architecture_force_regenerate(mock_session, mock_cache, mock_ai_service):
    """Test force regenerate skips cache"""
    service = ArchitectureService(mock_session, mock_cache, mock_ai_service)
    
    with patch.object(service.repository, 'create', return_value=Mock()):
        result = await service.generate(user_id=1, idea="Test idea", force_regenerate=True)
    
    # Should not check cache
    mock_cache.get.assert_not_called()
    # Should call AI service
    mock_ai_service.generate_architecture.assert_called_once()


@pytest.mark.asyncio
async def test_get_architecture_not_found(mock_session, mock_cache, mock_ai_service):
    """Test get architecture that doesn't exist"""
    service = ArchitectureService(mock_session, mock_cache, mock_ai_service)
    
    with patch.object(service.repository, 'get_by_id', return_value=None):
        with pytest.raises(NotFoundError):
            await service.get_by_id(architecture_id=999, user_id=1)


@pytest.mark.asyncio
async def test_list_architectures_pagination(mock_session, mock_cache, mock_ai_service):
    """Test architecture listing with pagination"""
    service = ArchitectureService(mock_session, mock_cache, mock_ai_service)
    
    mock_architectures = [
        Mock(id=1, idea="Test 1", architecture_type="Monolith", created_at=Mock(isoformat=lambda: "2024-01-01"), is_fallback=False),
        Mock(id=2, idea="Test 2", architecture_type="Microservices", created_at=Mock(isoformat=lambda: "2024-01-02"), is_fallback=False)
    ]
    
    with patch.object(service.repository, 'list_by_user', return_value=(mock_architectures, 2)):
        items, total, pages = await service.list_architectures(user_id=1, page=1, per_page=20)
    
    assert len(items) == 2
    assert total == 2
    assert pages == 1


@pytest.mark.asyncio
async def test_delete_architecture(mock_session, mock_cache, mock_ai_service):
    """Test architecture deletion"""
    service = ArchitectureService(mock_session, mock_cache, mock_ai_service)
    
    mock_arch = Mock(id=1, idea="Test idea")
    
    with patch.object(service.repository, 'get_by_id', return_value=mock_arch):
        with patch.object(service.repository, 'delete', return_value=True):
            result = await service.delete(architecture_id=1, user_id=1)
    
    assert result is True
    # Should clear cache
    mock_cache.delete.assert_called_once()


@pytest.mark.asyncio
async def test_create_user_duplicate_email(mock_session):
    """Test creating user with duplicate email"""
    service = UserService(mock_session)
    
    with patch.object(service.repository, 'get_by_email', return_value=Mock()):
        with patch.object(service.repository, 'create', side_effect=DuplicateResourceError("User", "email", "test@example.com")):
            with pytest.raises(DuplicateResourceError):
                await service.create_user("test@example.com", "password123")


@pytest.mark.asyncio
async def test_authenticate_user_success(mock_session):
    """Test successful user authentication"""
    service = UserService(mock_session)
    
    mock_user = Mock(
        id=1,
        email="test@example.com",
        password_hash="$2b$12$...",  # bcrypt hash
        is_active=True,
        api_key="test-api-key"
    )
    
    with patch.object(service.repository, 'get_by_email', return_value=mock_user):
        with patch('auth.verify_password', return_value=True):
            result = await service.authenticate("test@example.com", "password123")
    
    assert result is not None
    assert result["email"] == "test@example.com"


@pytest.mark.asyncio
async def test_authenticate_user_invalid_password(mock_session):
    """Test authentication with invalid password"""
    service = UserService(mock_session)
    
    mock_user = Mock(
        id=1,
        email="test@example.com",
        password_hash="$2b$12$...",
        is_active=True
    )
    
    with patch.object(service.repository, 'get_by_email', return_value=mock_user):
        with patch('auth.verify_password', return_value=False):
            result = await service.authenticate("test@example.com", "wrongpassword")
    
    assert result is None


@pytest.mark.asyncio
async def test_authenticate_user_inactive(mock_session):
    """Test authentication with inactive user"""
    service = UserService(mock_session)
    
    mock_user = Mock(
        id=1,
        email="test@example.com",
        is_active=False
    )
    
    with patch.object(service.repository, 'get_by_email', return_value=mock_user):
        result = await service.authenticate("test@example.com", "password123")
    
    assert result is None
