{
  "features": [
    {
      "name": "User Authentication & Authorization",
      "priority": "Must"
    },
    {
      "name": "Dashboard & Analytics",
      "priority": "Must"
    },
    {
      "name": "Data Management (CRUD)",
      "priority": "Must"
    },
    {
      "name": "Real-time Notifications",
      "priority": "Should"
    },
    {
      "name": "Search & Filtering",
      "priority": "Should"
    },
    {
      "name": "File Upload & Management",
      "priority": "Could"
    },
    {
      "name": "API Rate Limiting",
      "priority": "Should"
    },
    {
      "name": "Audit Logging",
      "priority": "Could"
    }
  ],
  "database": [
    {
      "table": "users",
      "fields": [
        "id",
        "email",
        "password_hash",
        "role",
        "created_at",
        "updated_at"
      ],
      "relationships": []
    },
    {
      "table": "sessions",
      "fields": [
        "id",
        "user_id",
        "token",
        "expires_at",
        "created_at"
      ],
      "relationships": [
        "FK -> users"
      ]
    },
    {
      "table": "audit_logs",
      "fields": [
        "id",
        "user_id",
        "action",
        "resource",
        "timestamp"
      ],
      "relationships": [
        "FK -> users"
      ]
    }
  ],
  "apis": [
    {
      "method": "POST",
      "endpoint": "/api/auth/register",
      "description": "User registration"
    },
    {
      "method": "POST",
      "endpoint": "/api/auth/login",
      "description": "User login"
    },
    {
      "method": "POST",
      "endpoint": "/api/auth/logout",
      "description": "User logout"
    },
    {
      "method": "GET",
      "endpoint": "/api/users/me",
      "description": "Get current user profile"
    },
    {
      "method": "PUT",
      "endpoint": "/api/users/me",
      "description": "Update user profile"
    },
    {
      "method": "GET",
      "endpoint": "/api/dashboard/stats",
      "description": "Get dashboard statistics"
    }
  ],
  "architecture": {
    "type": "Monolith",
    "components": [
      "React Frontend",
      "FastAPI Backend",
      "PostgreSQL Database",
      "Redis Cache",
      "Nginx Reverse Proxy"
    ],
    "tech_stack": {
      "frontend": "React + TypeScript",
      "backend": "FastAPI (Python)",
      "database": "PostgreSQL"
    }
  },
  "erDiagram": "erDiagram\n    USERS ||--o{ SESSIONS : has\n    USERS ||--o{ AUDIT_LOGS : generates\n    USERS {\n        int id PK\n        string email\n        string password_hash\n        string role\n        datetime created_at\n    }\n    SESSIONS {\n        int id PK\n        int user_id FK\n        string token\n        datetime expires_at\n    }\n    AUDIT_LOGS {\n        int id PK\n        int user_id FK\n        string action\n        string resource\n        datetime timestamp\n    }",
  "architectureDiagram": "graph TD\n    A[Browser Client] --> B[Nginx Reverse Proxy]\n    B --> C[React Frontend]\n    B --> D[FastAPI Backend]\n    D --> E[PostgreSQL Database]\n    D --> F[Redis Cache]\n    D --> G[File Storage]\n    style A fill:#6366f1,color:#fff\n    style D fill:#a855f7,color:#fff\n    style E fill:#3b82f6,color:#fff",
